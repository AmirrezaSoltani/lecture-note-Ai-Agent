APP_NAME=Lecture Note Builder
APP_HOST=127.0.0.1
APP_PORT=8000
DATA_DIR=./data
DATABASE_PATH=app.db
ASR_PROVIDER=auto
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=default
DEFAULT_LANGUAGE=tr
MAX_WORKERS=2
POLL_INTERVAL_SECONDS=1.0
ENABLE_PDF_EXPORT=true
ENABLE_DOCX_EXPORT=true
LOG_LEVEL=INFO
QUEUE_BACKEND=auto
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=lecture-processing
AI_ASSIST_MODE=heuristic

BASIC_AUTH_ENABLED=false
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me
BACKUP_DIR=backups


# Optional OpenAI polishing for final notes
LLM_NOTES_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_INPUT_CHARS=45000
